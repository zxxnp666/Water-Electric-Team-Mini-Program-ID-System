/* pages/cart/cart.wxss */

/* 统计行 */
.stats-row {
  display: flex;
  justify-content: space-around;
  padding: 16rpx 0;
}

.stat-item {
  text-align: center;
  flex: 1;
}

.stat-number {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--accent-color);
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 购物车列表 */
.cart-list {
  margin-bottom: 200rpx; /* 为底部操作区留空间 */
}

.cart-item {
  background: white;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 10rpx rgba(46, 52, 64, 0.05);
  display: flex;
  align-items: center;
  transition: all 0.3s ease;
}

.cart-item.select-mode {
  padding-left: 16rpx;
}

.cart-item:active {
  transform: translateY(2rpx);
  box-shadow: 0 1rpx 5rpx rgba(46, 52, 64, 0.1);
}

/* 选择框 */
.select-checkbox {
  margin-right: 16rpx;
}

.checkbox {
  width: 48rpx;
  height: 48rpx;
  border: 2rpx solid var(--border-color);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: transparent;
  font-size: 24rpx;
  font-weight: bold;
  transition: all 0.3s ease;
}

.checkbox.checked {
  background: var(--accent-color);
  border-color: var(--accent-color);
  color: white;
}

/* 物资信息 */
.cart-item-info {
  flex: 1;
  display: flex;
  align-items: center;
  margin-right: 16rpx;
}

.item-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #84fab0 0%, #8fd3f4 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 20rpx;
}

.item-details {
  flex: 1;
}

.item-name {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.item-spec {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 4rpx;
}

.item-stock {
  font-size: 22rpx;
  color: var(--success-color);
  margin-bottom: 4rpx;
}

.item-barcode {
  font-size: 20rpx;
  color: var(--text-secondary);
  opacity: 0.7;
}

/* 数量控制 */
.quantity-controls {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-right: 16rpx;
}

.quantity-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: var(--accent-color);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  transition: all 0.3s ease;
}

.quantity-btn:active {
  transform: scale(0.9);
  background: var(--secondary-color);
}

.quantity-input {
  width: 80rpx;
  padding: 12rpx;
  border: 2rpx solid var(--border-color);
  border-radius: 8rpx;
  text-align: center;
  font-size: 24rpx;
  background: white;
}

.unit-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  min-width: 40rpx;
}

.remove-item-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--error-color);
  border-radius: 50%;
  transition: all 0.3s ease;
}

.remove-item-btn:active {
  background: rgba(191, 97, 106, 0.1);
  transform: scale(0.9);
}

/* 底部操作区 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  padding: 24rpx;
  border-top: 1rpx solid var(--border-color);
  box-shadow: 0 -4rpx 20rpx rgba(46, 52, 64, 0.1);
  z-index: 100;
}

.action-summary {
  margin-bottom: 20rpx;
  text-align: center;
  padding: 16rpx;
  background: linear-gradient(135deg, #f8fbff 0%, #f0f8ff 100%);
  border-radius: 16rpx;
  border: 1rpx solid rgba(88, 166, 255, 0.1);
}

.summary-text {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.summary-user {
  display: inline-flex;
  align-items: center;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--accent-color);
  background: linear-gradient(135deg, rgba(88, 166, 255, 0.1), rgba(129, 199, 132, 0.1));
  padding: 12rpx 20rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(88, 166, 255, 0.2);
  max-width: 100%;
  box-shadow: 0 2rpx 8rpx rgba(88, 166, 255, 0.1);
  margin-top: 8rpx;
}

.user-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
  opacity: 0.8;
}

.user-text {
  flex: 1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 200rpx;
}

.action-buttons {
  display: flex;
  gap: 16rpx;
}

/* 空购物车状态 */
.empty-cart {
  text-align: center;
  padding: 100rpx 40rpx;
  color: var(--text-secondary);
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.empty-subtext {
  font-size: 24rpx;
  opacity: 0.6;
  margin-bottom: 32rpx;
}

/* 确认对话框 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 40rpx;
}

.modal-content {
  background: white;
  border-radius: 20rpx;
  max-width: 600rpx;
  width: 100%;
  max-height: 80vh;
  overflow-y: auto;
}

.modal-header {
  padding: 32rpx 32rpx 16rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  color: var(--text-primary);
}

.modal-body {
  padding: 32rpx;
}

.confirm-section {
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--bg-secondary);
}

.confirm-section:last-of-type {
  border-bottom: none;
}

.confirm-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.confirm-value {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.confirm-materials {
  max-height: 300rpx;
  overflow-y: auto;
  border: 1rpx solid var(--border-color);
  border-radius: 12rpx;
  padding: 16rpx;
  background: var(--bg-primary);
}

.confirm-material {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.confirm-material:last-child {
  border-bottom: none;
}

.material-name {
  font-size: 24rpx;
  color: var(--text-primary);
  flex: 1;
}

.material-quantity {
  font-size: 24rpx;
  font-weight: bold;
  color: var(--accent-color);
}

.modal-footer {
  padding: 16rpx 32rpx 32rpx;
  display: flex;
  gap: 16rpx;
}

/* 领用人信息样式优化 */
.form-group {
  position: relative;
}

.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
}

.form-label::before {
  content: '';
  width: 6rpx;
  height: 28rpx;
  background: linear-gradient(135deg, var(--accent-color), var(--success-color));
  border-radius: 3rpx;
  margin-right: 12rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  border: 2rpx solid #e8f4fd;
  border-radius: 16rpx;
  font-size: 28rpx;
  background: linear-gradient(135deg, #f8fbff 0%, #f0f8ff 100%);
  box-sizing: border-box;
  transition: all 0.3s ease;
  box-shadow: 0 2rpx 12rpx rgba(88, 166, 255, 0.08);
}

.form-input:focus {
  border-color: var(--accent-color);
  background: white;
  box-shadow: 0 4rpx 20rpx rgba(88, 166, 255, 0.15);
  transform: translateY(-2rpx);
}

.form-input::placeholder {
  color: #bbb;
  font-size: 26rpx;
}

/* 响应式调整 */
@media screen and (max-width: 400px) {
  .cart-item {
    padding: 16rpx;
  }
  
  .item-icon {
    width: 60rpx;
    height: 60rpx;
    font-size: 24rpx;
  }
  
  .quantity-btn {
    width: 48rpx;
    height: 48rpx;
    font-size: 24rpx;
  }
  
  .quantity-input {
    width: 60rpx;
  }
}

