/* pages/scan/scan.wxss */

/* 扫码主卡片 */
.scan-main-card {
  background: white;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  position: relative;
  overflow: hidden;
}

.scan-main-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 8rpx;
  background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
}

/* 扫码头部 */
.scan-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.scan-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.scan-subtitle {
  font-size: 26rpx;
  color: #666;
}

/* 扫码区域 */
.scan-area {
  display: flex;
  justify-content: center;
  margin-bottom: 40rpx;
}

.scan-frame {
  position: relative;
  width: 320rpx;
  height: 320rpx;
  background: linear-gradient(135deg, #f8f9ff 0%, #e8f0ff 100%);
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 4rpx dashed #667eea;
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.1);
}

/* 扫码框四角 */
.scan-corners {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
}

.corner {
  position: absolute;
  width: 40rpx;
  height: 40rpx;
  border: 6rpx solid #667eea;
}

.corner-tl {
  top: -3rpx;
  left: -3rpx;
  border-right: none;
  border-bottom: none;
  border-radius: 20rpx 0 0 0;
}

.corner-tr {
  top: -3rpx;
  right: -3rpx;
  border-left: none;
  border-bottom: none;
  border-radius: 0 20rpx 0 0;
}

.corner-bl {
  bottom: -3rpx;
  left: -3rpx;
  border-right: none;
  border-top: none;
  border-radius: 0 0 0 20rpx;
}

.corner-br {
  bottom: -3rpx;
  right: -3rpx;
  border-left: none;
  border-top: none;
  border-radius: 0 0 20rpx 0;
}

.scan-icon-large {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  animation: pulse 2s infinite;
  filter: drop-shadow(0 2rpx 8rpx rgba(102, 126, 234, 0.3));
}

@keyframes pulse {
  0% { transform: scale(1); opacity: 0.8; }
  50% { transform: scale(1.05); opacity: 1; }
  100% { transform: scale(1); opacity: 0.8; }
}

.scan-hint {
  font-size: 24rpx;
  color: #667eea;
  font-weight: bold;
}

/* 扫码操作按钮 */
.scan-actions {
  display: flex;
  justify-content: center;
  margin-bottom: 30rpx;
}

.scan-btn-primary {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 60rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.4);
  transition: all 0.3s ease;
  min-width: 280rpx;
}

.scan-btn-primary:active {
  transform: translateY(4rpx) scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.4);
}

.scan-btn-icon {
  font-size: 40rpx;
  margin-bottom: 12rpx;
}

.scan-btn-text {
  font-size: 30rpx;
  font-weight: bold;
  letter-spacing: 2rpx;
}

/* 扫码提示 */
.scan-tips {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tip-item {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background: #f8f9ff;
  border-radius: 12rpx;
  border-left: 6rpx solid #667eea;
}

.tip-icon {
  font-size: 24rpx;
  margin-right: 16rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #666;
}

/* 扫码覆盖层 */
.scan-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.3);
}

/* 扫码框架 */
.scan-frame {
  width: 300rpx;
  height: 300rpx;
  border: 4rpx solid #A3BE8C;
  border-radius: 16rpx;
  position: relative;
  background: transparent;
}

.scan-frame::before,
.scan-frame::after {
  content: '';
  position: absolute;
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #A3BE8C;
}

.scan-frame::before {
  top: -6rpx;
  left: -6rpx;
  border-right: none;
  border-bottom: none;
  border-radius: 16rpx 0 0 0;
}

.scan-frame::after {
  bottom: -6rpx;
  right: -6rpx;
  border-left: none;
  border-top: none;
  border-radius: 0 0 16rpx 0;
}

/* 扫码提示 */
.scan-tips {
  color: white;
  font-size: 28rpx;
  margin-top: 40rpx;
  text-align: center;
  background: rgba(0, 0, 0, 0.5);
  padding: 16rpx 32rpx;
  border-radius: 32rpx;
}


/* 已扫描物资列表 */
.scanned-list {
  max-height: 600rpx;
  overflow-y: auto;
}

.scanned-item {
  padding: 24rpx;
  border-bottom: 1rpx solid var(--border-color);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.scanned-item:last-child {
  border-bottom: none;
}

.scanned-info {
  flex: 1;
  margin-right: 24rpx;
}

.scanned-name {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.scanned-spec {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 4rpx;
}

.scanned-stock {
  font-size: 22rpx;
  color: var(--success-color);
}

.scanned-controls {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.quantity-input {
  width: 80rpx;
  padding: 12rpx;
  border: 2rpx solid var(--border-color);
  border-radius: 8rpx;
  text-align: center;
  font-size: 24rpx;
  background: white;
}

.unit-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  min-width: 40rpx;
}

.remove-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: var(--error-color);
  border-radius: 50%;
  transition: all 0.3s ease;
}

.remove-btn:active {
  background: rgba(191, 97, 106, 0.1);
  transform: scale(0.9);
}

/* 历史记录特殊样式 */
.history-item {
  background: rgba(94, 129, 172, 0.05);
  border-left: 4rpx solid var(--accent-color);
}

/* 响应式调整 */
@media screen and (max-width: 400px) {
  .scan-container {
    height: 300rpx;
  }
  
  .scan-frame {
    width: 200rpx;
    height: 200rpx;
  }
  
}

/* 数量选择对话框样式 */
.quantity-dialog-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.quantity-dialog {
  width: 600rpx;
  background: white;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.2);
}

.dialog-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  background: #f8f9fa;
}

.dialog-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.dialog-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #999;
  border-radius: 50%;
  background: #f0f0f0;
}

.dialog-content {
  padding: 32rpx;
}

/* 物资信息 */
.material-info {
  margin-bottom: 32rpx;
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
}

.material-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.material-spec {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.material-stock {
  font-size: 26rpx;
  color: #007aff;
  font-weight: 500;
}

/* 数量选择器 */
.quantity-selector {
  margin-bottom: 32rpx;
}

.quantity-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.quantity-controls {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.quantity-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #007aff;
  color: white;
  border-radius: 50%;
  font-size: 32rpx;
  font-weight: bold;
}

.quantity-btn.disabled {
  background: #e0e0e0;
  color: #999;
}

.quantity-input {
  width: 120rpx;
  height: 64rpx;
  text-align: center;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  background: white;
  outline: none;
}

.quantity-input:focus {
  border-color: #007aff;
  box-shadow: 0 0 0 2rpx rgba(0, 122, 255, 0.2);
}

.quantity-unit {
  margin-left: 16rpx;
  font-size: 26rpx;
  color: #666;
}

/* 快速选择 */
.quick-select {
  margin-bottom: 16rpx;
}

.quick-select-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.quick-select-buttons {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.quick-btn {
  padding: 16rpx 24rpx;
  background: #f0f0f0;
  color: #333;
  border-radius: 12rpx;
  font-size: 26rpx;
  text-align: center;
  min-width: 80rpx;
  cursor: pointer;
  transition: all 0.2s ease;
}

.quick-btn:active {
  transform: scale(0.95);
  background: #e0e0e0;
}

.quick-btn.active {
  background: #007aff;
  color: white;
}

.quick-btn.active:active {
  background: #0056cc;
}

/* 对话框底部 */
.dialog-footer {
  display: flex;
  border-top: 1rpx solid #f0f0f0;
}

.dialog-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 500;
}

.cancel-btn {
  color: #666;
  background: #f8f9fa;
}

.confirm-btn {
  color: white;
  background: #007aff;
}

