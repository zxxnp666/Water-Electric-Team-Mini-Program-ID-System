/* pages/history/history.wxss */

/* 主容器 */
.main-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding-bottom: 120rpx;
}

.container {
  padding: 20rpx;
}

/* 卡片样式 */
.card {
  background: white;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
  overflow: hidden;
}

.card-header {
  padding: 30rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.card-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.card-subtitle {
  font-size: 28rpx;
  opacity: 0.9;
}

.card-body {
  padding: 30rpx;
}

/* 筛选条件 */
.date-filter-section {
  padding: 10rpx 0;
}

.filter-label {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 20rpx;
  font-weight: 600;
  text-align: center;
}

.date-picker-row {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.date-picker-item {
  flex: 1;
  max-width: 280rpx;
}

.date-picker-text {
  padding: 24rpx 20rpx;
  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #495057;
  text-align: center;
  border: 2rpx solid #dee2e6;
  transition: all 0.3s ease;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.date-picker-text:active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border-color: #667eea;
}

.date-separator {
  margin: 0 20rpx;
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
}

.filter-actions {
  display: flex;
  gap: 20rpx;
  justify-content: center;
}

/* 按钮样式 */
.btn {
  padding: 20rpx 30rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  text-align: center;
  transition: all 0.3s ease;
}

.btn-outline {
  background: white;
  color: #667eea;
  border: 2rpx solid #667eea;
}

.btn-outline:active {
  background: #667eea;
  color: white;
}

.btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
}

.btn-primary:active {
  opacity: 0.8;
}

/* 统计信息 */
.stats-row {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  text-align: center;
}

.stat-number {
  font-size: 48rpx;
  font-weight: bold;
  color: #667eea;
  margin-bottom: 10rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #666;
}

/* 历史记录列表 */
.history-list {
  margin-top: 20rpx;
}

.history-item {
  background: white;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
  overflow: hidden;
  transition: all 0.3s ease;
}

.history-item:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
  border-bottom: 1rpx solid #dee2e6;
}

.record-info {
  flex: 1;
}

.record-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.record-time {
  font-size: 24rpx;
  color: #666;
}

.record-status {
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.record-status.success {
  background: #d4edda;
  color: #155724;
}

.record-status.warning {
  background: #fff3cd;
  color: #856404;
}

.record-details {
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.detail-row:last-child {
  margin-bottom: 0;
}

.detail-label {
  font-size: 28rpx;
  color: #666;
}

.detail-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.record-materials {
  padding: 20rpx 30rpx;
  background: #f8f9fa;
  border-bottom: 1rpx solid #f0f0f0;
}

.material-summary {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

.record-actions {
  display: flex;
  padding: 20rpx 30rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  margin: 0 10rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #667eea;
  transition: all 0.3s ease;
}

.action-btn:first-child {
  margin-left: 0;
}

.action-btn:last-child {
  margin-right: 0;
}

.action-btn:active {
  background: #667eea;
  color: white;
}

.action-btn .icon {
  margin-right: 8rpx;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 40rpx 0;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 40rpx;
  color: white;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 32rpx;
  margin-bottom: 15rpx;
  opacity: 0.9;
}

.empty-subtext {
  font-size: 28rpx;
  opacity: 0.7;
}

/* 加载状态 */
.loading {
  text-align: center;
  padding: 40rpx;
  color: white;
  font-size: 28rpx;
}

/* 弹窗样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 40rpx;
}

.modal-content {
  background: white;
  border-radius: 20rpx;
  max-height: 80vh;
  width: 100%;
  max-width: 600rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
}

.modal-close {
  font-size: 36rpx;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
}

.modal-body {
  flex: 1;
  overflow-y: auto;
  padding: 30rpx;
}

.detail-section {
  margin-bottom: 40rpx;
}

.detail-section:last-child {
  margin-bottom: 0;
}

.detail-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 10rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.detail-info {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 20rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15rpx 0;
  border-bottom: 1rpx solid #e9ecef;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #666;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.status-success {
  color: #28a745;
}

.status-warning {
  color: #ffc107;
}

.materials-detail {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 20rpx;
}

.material-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #e9ecef;
}

.material-item:last-child {
  border-bottom: none;
}

.material-info {
  flex: 1;
}

.material-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.material-spec {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.material-barcode {
  font-size: 24rpx;
  color: #999;
}

.material-quantity {
  text-align: right;
  margin-left: 20rpx;
}

.quantity-number {
  font-size: 32rpx;
  font-weight: bold;
  color: #667eea;
}

.quantity-unit {
  font-size: 24rpx;
  color: #666;
}

.modal-footer {
  display: flex;
  padding: 30rpx;
  border-top: 1rpx solid #f0f0f0;
  gap: 20rpx;
}

.flex-1 {
  flex: 1;
}

/* 状态管理按钮 */
.status-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

/* 状态管理对话框 */
.status-info {
  margin-bottom: 30rpx;
}

.status-info .info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.status-info .info-label {
  font-size: 28rpx;
  color: #666;
  font-weight: bold;
}

.status-info .info-value {
  font-size: 28rpx;
  color: #333;
}

.status-current {
  font-weight: bold;
  color: #ff9500;
}

.status-options {
  margin-top: 20rpx;
}

.status-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.status-buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.status-option {
  flex: 1;
  min-width: 140rpx;
  padding: 20rpx 16rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: bold;
  background: white;
  transition: all 0.3s ease;
}

.status-option:active {
  transform: scale(0.95);
  background: rgba(0, 0, 0, 0.05);
}